# App
APP_PORT=3001
APP_NAME=auth-service
APP_ENV=test

# CORS
APP_CORS_ENABLE=true
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-API-KEY,Set-Cookie,Access-Control-Allow-Credentials,Access-Control-Allow-Headers,Access-Control-Allow-Methods,Access-Control-Allow-Origin
APP_CORS_ALLOWED_METHODS=GET,PUT,POST,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,http://127.0.0.1:3001
APP_CORS_MAX_AGE_SECONDS=300

# Database (PostgreSQL)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=oil_auth_test
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=postgres
DB_POSTGRES_TIMEZONE=UTC
DB_POSTGRES_SSL_MODE=disable

# Database settings
DB_POSTGRES_MAX_RETRY=3
DB_POSTGRES_RETRY_WAIT_TIME=5
DB_POSTGRES_MIGRATION_TABLE=migrations
DB_POSTGRES_AUTO_MIGRATE=false
DB_POSTGRES_PREFIX=

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenTelemetry
OTEL_ENABLED=false

# Better Auth
BETTER_AUTH_URL=http://localhost:3001

# Logger
LOG_LEVEL=error
