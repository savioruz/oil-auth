# App
APP_PORT=3000
APP_NAME=auth-service
APP_ENV=development

# CORS
APP_CORS_ENABLE=true
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-API-KEY,Set-Cookie
APP_CORS_ALLOWED_METHODS=GET,PUT,POST,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_CORS_MAX_AGE_SECONDS=300

# Logger
LOG_LEVEL=info

# Database (PostgreSQL)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=oil_auth
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=
DB_POSTGRES_TIMEZONE=UTC
DB_POSTGRES_SSL_MODE=disable

# Cache
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=strongpassword
CACHE_REDIS_DB=0
CACHE_REDIS_TLS=false

# OpenTelemetry
OTEL_ENABLED=true
OTEL_PROTOCOL=grpc
OTEL_ENDPOINT=localhost:4317

# Session
SESSION_EXPIRES_IN=604800
SESSION_UPDATE_AGE=86400
SESSION_COOKIE_CACHE_MAX_AGE=300

# Auth
AUTH_BASE_URL=http://localhost:3000
AUTH_SECRET_KEY=your_secret_key
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
